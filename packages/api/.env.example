# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]
JWT_SECRET=your-secret-key-here

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/trading
REDIS_URL=redis://localhost:6379/0

# Broker
BROKER_ADAPTER=paper
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_ACCESS_TOKEN=
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# Data Vendor
DATA_VENDOR=mock
DATA_VENDOR_API_KEY=

# LLM
GROQ_API_KEY=
LLM_PROVIDER=groq
LOCAL_LLM_URL=http://localhost:11434

# Agent Config
MAX_AGENTS=20
AGENT_IDLE_TIMEOUT_SEC=300
AGENT_RETIRE_TIMEOUT_SEC=900
ENABLE_TRANSCRIPT_LOGGING=false

# Risk Params
MAX_DAILY_LOSS=20000
MAX_DRAWDOWN_PCT=10
MAX_POSITION_SIZE=4
MAX_MARGIN_UTIL_PCT=90
